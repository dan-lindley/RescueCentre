Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Preserve Authorization headers for API/login requests.
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Never rewrite real files or directories. This keeps CSS, JS, images,
    # uploads, and install assets loading normally.
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Route friendly URLs to front controller only when no real file exists.
    RewriteRule ^ index.php [L]
</IfModule>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
</IfModule>
